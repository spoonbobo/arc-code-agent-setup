#!/usr/bin/env python3
"""
Generic ARC-AGI-3 Remote Attempt Launcher Template

This is a template for running remote ARC-AGI-3 game attempts.
Copy this file to your project root and customize as needed.

Usage:
    uv run python launch.py
    ARC_GAME_ID=ls20-cb3b57cc uv run python launch.py
    ARC_OPERATION_MODE=offline uv run python launch.py
"""

from __future__ import annotations

import os
import sys
from dataclasses import dataclass, field
from typing import Any

import dotenv
from arc_agi import Arcade, OperationMode
from arcengine import GameAction


@dataclass(slots=True)
class AttemptConfig:
    game_id: str = "ls20"
    steps: int = 10
    action: GameAction = GameAction.ACTION1
    operation_mode: OperationMode = OperationMode.ONLINE
    render_terminal: bool = False
    existing_scorecard_id: str | None = None
    tags: list[str] = field(default_factory=list)
    note: str | None = None


@dataclass(slots=True)
class AttemptResult:
    scorecard_id: str | None
    final_scorecard: Any


def parse_operation_mode(value: str) -> OperationMode:
    normalized = value.strip().lower()
    if normalized == "online":
        return OperationMode.ONLINE
    if normalized == "offline":
        return OperationMode.OFFLINE
    raise ValueError(f"Unsupported operation mode: {value}")


def build_scorecard_tags(game_id: str, extra_tags: list[str]) -> list[str]:
    tags: list[str] = []
    for tag in ["remote-attempt", f"game:{game_id}", *extra_tags]:
        cleaned_tag = tag.strip()
        if cleaned_tag and cleaned_tag not in tags:
            tags.append(cleaned_tag)
    return tags


def build_attempt_opaque(config: AttemptConfig) -> dict[str, object]:
    opaque: dict[str, object] = {
        "game_id": config.game_id,
        "planned_steps": config.steps,
        "action": config.action.name,
        "mode": config.operation_mode.name,
    }
    if config.note:
        opaque["note"] = config.note
    return opaque


def run_remote_attempt(arc: Any, config: AttemptConfig) -> AttemptResult:
    scorecard_id = config.existing_scorecard_id
    final_scorecard = None

    if config.operation_mode is OperationMode.ONLINE:
        if scorecard_id:
            arc.open_scorecard(scorecard_id=scorecard_id)
        else:
            scorecard_id = arc.create_scorecard(
                tags=build_scorecard_tags(config.game_id, config.tags),
                opaque=build_attempt_opaque(config),
            )

    environment = arc.make(
        config.game_id,
        render_mode="terminal" if config.render_terminal else None,
        scorecard_id=scorecard_id,
    )
    if environment is None:
        raise RuntimeError(f"Failed to create environment for game {config.game_id}")

    try:
        for step_index in range(1, config.steps + 1):
            abs = environment.step(
                config.action,
                reasoning={
                    "thought": "sample remote attempt step",
                    "step_index": step_index,
                    "planned_steps": config.steps,
                },
            )
            print("action space", abs)

    finally:
        if config.operation_mode is OperationMode.ONLINE:
            final_scorecard = arc.close_scorecard(scorecard_id=scorecard_id)

    return AttemptResult(scorecard_id=scorecard_id, final_scorecard=final_scorecard)


def get_operation_mode() -> OperationMode:
    mode = os.getenv("ARC_OPERATION_MODE", "normal").lower()
    if mode == "online":
        return OperationMode.ONLINE
    if mode == "offline":
        return OperationMode.OFFLINE
    return OperationMode.NORMAL


def get_game_id(arc: Arcade) -> str:
    env_game_id = os.getenv("ARC_GAME_ID", "").strip()
    if env_game_id:
        print(f"Using game from ARC_GAME_ID: {env_game_id}")
        return env_game_id

    print("ARC_GAME_ID not set, discovering available games...")
    games = arc.get_environments()

    if not games:
        print("ERROR: No games available!", file=sys.stderr)
        sys.exit(1)

    print(f"Found {len(games)} game(s):")
    for g in games:
        print(f"  - {g.game_id}: {g.title}")

    selected = games[0].game_id
    print(f"\nAuto-selected: {selected}")
    return selected


def main() -> None:
    dotenv.load_dotenv()

    render_terminal = False
    existing_scorecard_id = None

    operation_mode = get_operation_mode()
    print(f"Operation mode: {operation_mode.name}")

    arc = Arcade(operation_mode=operation_mode)
    game_id = get_game_id(arc)

    config = AttemptConfig(
        game_id=game_id,
        steps=10,
        action=GameAction.ACTION1,
        operation_mode=operation_mode,
        render_terminal=render_terminal,
        existing_scorecard_id=existing_scorecard_id,
        tags=["sample-launch"],
        note="sample launcher remote attempt",
    )

    result = run_remote_attempt(arc, config)

    print(f"Scorecard ID: {result.scorecard_id}")
    if result.final_scorecard is not None:
        print(f"Score: {result.final_scorecard.score}")
        print("\nFull scorecard:")
        print(result.final_scorecard.model_dump_json(indent=2))


if __name__ == "__main__":
    main()
